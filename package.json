{
  "name": "financial-tracker-wabot-bun",
  "version": "1.0.0",
  "description": "WhatsApp financial tracking bot with Ollama AI",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio",
    "build": "bun build src/index.ts --outdir dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  }
}