# App
NODE_ENV=production
ADMIN_API_KEY=your-admin-api-key
TZ=Asia/Jakarta

# Database (used by docker-compose)
POSTGRES_USER=finbot
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=financial_tracker

# Database URL (auto-composed in docker-compose, set manually if running outside Docker)
DATABASE_URL=postgresql://finbot:change-me-strong-password@localhost:5432/financial_tracker

# Ollama
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_MODEL=qwen3.5
